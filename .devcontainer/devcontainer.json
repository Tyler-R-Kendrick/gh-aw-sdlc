{
  "name": "OctoCAT Supply",
  "image": "mcr.microsoft.com/devcontainers/universal",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker": {},
    "ghcr.io/devcontainers-extra/features/act": {}
  },
  "postCreateCommand": "npm ci && gh extension install github/gh-aw && npm install skills",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "github.vscode-github-actions"
      ]
    }
  }
}
